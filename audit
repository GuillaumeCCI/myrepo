function ZoomControls({ zoom, setZoom }) {
  return (
    <div style={{ position:"fixed", bottom:32, right:32, display:"flex", flexDirection:"column", gap:8, background:"white", padding:8, borderRadius:12, boxShadow:"0 8px 24px rgba(0,0,0,0.12)", border:"1px solid #e5e7eb", zIndex:50 }}>
      <button onClick={() => setZoom(z => Math.min(z + 0.1, 2))} style={btnStyle} title="Zoom +"><ZoomInIcon /></button>
      <div style={{ textAlign:"center", fontSize:11, fontFamily:"monospace", color:"#6b7280", padding:"4px 0", borderTop:"1px solid #f3f4f6", borderBottom:"1px solid #f3f4f6" }}>
        {Math.round(zoom * 100)}%
      </div>
      <button onClick={() => setZoom(z => Math.max(z - 0.1, 0.5))} style={btnStyle} title="Zoom -"><ZoomOutIcon /></button>
      <button onClick={() => setZoom(1)} style={{ ...btnStyle, color:"#2563eb" }} title="Reset"><ResetIcon /></button>
    </div>
  );
}
