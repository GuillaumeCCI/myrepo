<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tutoriel Navigation - 1001 Parcours</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; background-color: #f8fafc; }
        .pulse-animation { animation: pulse-ring 2s cubic-bezier(0.4,0,0.6,1) infinite; }
        @keyframes pulse-ring { 0%,100%{transform:scale(1);opacity:1} 50%{transform:scale(1.05);opacity:0.8} }
        .sidebar-link { display:flex; align-items:flex-start; gap:8px; padding:6px 8px; border-radius:4px; font-size:0.82rem; color:#2563eb; cursor:pointer; transition:background 0.15s; text-decoration:none; }
        .sidebar-link:hover { background:#eff6ff; }
        .sidebar-link.active { background:#2563eb; color:white; font-weight:600; }
        .sidebar-link.active .dot { border-color:white; background:white; }
        .dot { width:14px; height:14px; border-radius:50%; border:2px solid #9ca3af; background:white; flex-shrink:0; margin-top:2px; }
        .dot.filled { border-color:#2563eb; background:#2563eb; }
        .section-title { font-weight:700; font-size:0.85rem; color:#1f2937; display:flex; align-items:center; gap:6px; padding:6px 4px; }
        .dashed-line { border-left:2px dashed #d1d5db; margin-left:6px; padding-left:16px; }
        .view-panel { display:none; }
        .view-panel.active { display:block; }
    </style>
</head>
<body class="text-gray-800">

<!-- Header -->
