            <div class="flex gap-4"><button class="bg-[#3b5998] text-white px-5 py-2 rounded text-sm">Marquer comme terminé</button><button onclick="goTo('commencer')" class="bg-white text-[#3b5998] border border-[#3b5998] px-5 py-2 rounded text-sm">Suivant</button></div>
        </div>
        <div id="view-commencer" class="view-panel">
