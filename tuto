<!-- OVERLAY TUTORIEL -->
<div id="tutorial-container" style="display:none; position:fixed; inset:0; z-index:99999; pointer-events:none;">
    <!-- Spotlight via box-shadow uniquement -->
    <div id="tutorial-hole" style="position:fixed; z-index:2; pointer-events:none; box-shadow:0 0 0 9999px rgba(0,0,0,0.45); border:3px solid #598378; border-radius:6px; transition:all 0.4s ease;"></div>
    <!-- Zone cliquable interactive sur le spotlight -->
    <div id="tutorial-interactive-area" style="display:none; position:fixed; z-index:3; cursor:pointer; border-radius:6px; pointer-events:auto;" onclick="handleInteractiveClick()"></div>
    <!-- Tooltip -->
    <div id="tutorial-tooltip" style="position:fixed; z-index:10; width:310px; background:white; border-radius:12px; box-shadow:0 20px 60px rgba(0,0,0,0.3); border-top:6px solid #598378; transition:all 0.4s ease; pointer-events:auto;">
        <div style="padding:18px 18px 12px;">
            <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:8px;">
                <span id="tut-badge" style="font-size:10px; font-weight:700; color:#598378; background:#f0faf7; padding:3px 8px; border-radius:4px; letter-spacing:0.5px; text-transform:uppercase;"></span>
                <button onclick="endTutorial()" style="color:#9ca3af; background:none; border:none; cursor:pointer; font-size:14px; padding:0; pointer-events:auto;">✕</button>
            </div>
            <p id="tut-text" style="font-size:13px; color:#1f2937; line-height:1.6; font-weight:500; margin-top:10px;"></p>
        </div>
        <div style="background:#f9fafb; padding:10px 16px; border-radius:0 0 10px 10px; border-top:1px solid #f3f4f6; display:flex; justify-content:space-between; align-items:center;">
            <span id="tut-counter" style="font-size:11px; font-weight:700; color:#9ca3af;"></span>
            <div style="display:flex; gap:8px;">
                <button id="tut-prev" onclick="prevStep()" style="background:none; border:none; color:#6b7280; cursor:pointer; font-size:12px; padding:4px 8px; border-radius:4px; pointer-events:auto;">← Préc.</button>
                <button id="tut-next" onclick="nextStep()" style="background:#598378; color:white; border:none; cursor:pointer; font-size:12px; padding:6px 14px; border-radius:6px; font-weight:700; pointer-events:auto;">Suivant →</button>
            </div>
        </div>
    </div>
</div>

<script>
let currentStep = 0;
let isTutorialActive = false;
let currentContentPage = 1;

// Navigation contenu pédagogique
function contentGoRight() {
    currentContentPage = 2;
    document.getElementById('content-page-1').style.display = 'none';
    document.getElementById('content-page-2').style.display = 'block';
    if (isTutorialActive && steps[currentStep] && steps[currentStep].waitForRightArrow) {
        // Basculer : masquer droite, afficher gauche
        document.getElementById('btn-right-overlay').style.display = 'none';
        document.getElementById('btn-home-overlay').style.display  = 'none';
        document.getElementById('btn-left-overlay').style.display  = 'block';
        // Mettre à jour le texte, afficher Suivant — bulle et encadré restent en place
        document.getElementById('tut-text').textContent = '⬅️ Vous êtes sur la page 2 ! Cliquez sur la flèche gauche pour revenir à la page précédente. Naviguez autant que vous voulez, puis cliquez sur Suivant quand vous êtes prêt.';
        const nextBtn = document.getElementById('tut-next');
        nextBtn.innerHTML = 'Suivant →';
        nextBtn.style.background = '#598378';
        nextBtn.style.display = 'inline-block';
    }
}
function hidePanelOverlays() {
    ['btn-home-overlay','btn-right-overlay','btn-left-overlay'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.style.display = 'none';
    });
}
function contentGoLeft() {
    currentContentPage = 1;
    document.getElementById('content-page-1').style.display = 'block';
    document.getElementById('content-page-2').style.display = 'none';
    if (isTutorialActive && steps[currentStep] && steps[currentStep].waitForRightArrow) {
        // Retour page 1 : masquer gauche, réafficher droite
        document.getElementById('btn-left-overlay').style.display  = 'none';
        document.getElementById('btn-right-overlay').style.display = 'block';
        document.getElementById('btn-home-overlay').style.display  = 'block';
        // Remettre le texte initial, garder Suivant visible
        document.getElementById('tut-text').textContent = '➡️ Les flèches permettent de naviguer entre les pages d\'une même séquence. La maison 🏠 revient à la première page. Cliquez sur la flèche droite pour voir la page suivante !';
    }
}
function contentGoHome() {
    contentGoLeft();
}

function resetBottomNav() {
    const btn = document.getElementById('btn-marquer');
    if (btn) { btn.style.opacity = '1'; btn.style.pointerEvents = 'auto'; }
    const suivant = document.getElementById('btn-suivant-cadre');
    if (suivant) { suivant.style.opacity = '0.35'; suivant.style.pointerEvents = 'none'; }
    // Remettre le cercle vide
    const dot = document.querySelector('#nav-cadre .dot');
    if (dot) { dot.style.background = 'white'; dot.style.borderColor = '#9ca3af'; }
}

function marquerTermine() {
    // Remplir le cercle vert dans le plan
    const navEl = document.getElementById('nav-cadre');
    if (navEl) {
        const dot = navEl.querySelector('.dot');
        if (dot) {
            dot.style.background = '#16a34a';
            dot.style.borderColor = '#16a34a';
        }
    }
    // Griser Marquer, activer Suivant
    const btn = document.getElementById('btn-marquer');
    if (btn) { btn.style.opacity = '0.5'; btn.style.pointerEvents = 'none'; }
    const suivant = document.getElementById('btn-suivant-cadre');
    if (suivant) { suivant.style.opacity = '1'; suivant.style.pointerEvents = 'auto'; }

    // Si tuto actif étape 5 : déplacer spotlight sur le cercle vert + nouvelle bulle
    if (isTutorialActive && steps[currentStep] && currentStep === 4) {
        setTimeout(() => {
            const dotEl = document.querySelector('#nav-cadre .dot');
            if (!dotEl) return;
            dotEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            setTimeout(() => {
                const rect = dotEl.getBoundingClientRect();
                const pad = 10;
                const hole = document.getElementById('tutorial-hole');
                hole.style.top    = (rect.top    - pad) + 'px';
                hole.style.left   = (rect.left   - pad) + 'px';
                hole.style.width  = (rect.width  + pad * 2) + 'px';
                hole.style.height = (rect.height + pad * 2) + 'px';

                // Phase 1 : spotlight sur le cercle vert
                document.getElementById('tut-text').textContent = '🟢 Le cercle est maintenant vert : la séquence est marquée comme terminée !';
                const tt = document.getElementById('tutorial-tooltip');
                const vW = window.innerWidth, vH = window.innerHeight;
                const ttW = 310, ttH = 140;
                let top1  = rect.top + rect.height / 2 - ttH / 2;
                let left1 = rect.right + 16;
                top1  = Math.max(10, Math.min(top1,  vH - ttH - 10));
                left1 = Math.max(10, Math.min(left1, vW - ttW - 10));
                tt.style.top  = top1 + 'px';
                tt.style.left = left1 + 'px';
                // Cacher le bouton Suivant de la bulle tuto
                document.getElementById('tut-next').style.display = 'none';

                // Phase 2 : après 1.5s, basculer spotlight sur btn-suivant-cadre
                setTimeout(() => {
                    const suivantEl = document.getElementById('btn-suivant-cadre');
                    if (!suivantEl) return;
                    suivantEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                    setTimeout(() => {
                        const r2 = suivantEl.getBoundingClientRect();
                        const pad2 = 8;
                        const hole = document.getElementById('tutorial-hole');
                        hole.style.top    = (r2.top    - pad2) + 'px';
                        hole.style.left   = (r2.left   - pad2) + 'px';
                        hole.style.width  = (r2.width  + pad2*2) + 'px';
                        hole.style.height = (r2.height + pad2*2) + 'px';

                        // Zone cliquable interactive sur le bouton Suivant
                        const iarea = document.getElementById('tutorial-interactive-area');
                        iarea.style.display = 'block';
                        iarea.style.top    = (r2.top    - pad2) + 'px';
                        iarea.style.left   = (r2.left   - pad2) + 'px';
                        iarea.style.width  = (r2.width  + pad2*2) + 'px';
                        iarea.style.height = (r2.height + pad2*2) + 'px';
                        // Le clic sur la zone = clic réel sur le bouton
                        document.getElementById('tutorial-interactive-area').onclick = function() {
                            document.getElementById('tutorial-interactive-area').style.display = 'none';
                            suivantEl.click();
                            nextStep();
                        };

                        // Mettre à jour bulle
                        document.getElementById('tut-text').textContent = '👉 Cliquez maintenant sur "Suivant" pour passer à la séquence suivante.';
                        const tt2 = document.getElementById('tutorial-tooltip');
                        let top2  = r2.top - ttH - 16;
                        let left2 = r2.left + r2.width/2 - ttW/2;
                        top2  = Math.max(10, Math.min(top2,  vH - ttH - 10));
                        left2 = Math.max(10, Math.min(left2, vW - ttW - 10));
                        tt2.style.top  = top2 + 'px';
                        tt2.style.left = left2 + 'px';
                    }, 350);
                }, 1200);
            }, 350);
        }, 100);
    }
}

function showView(id) {
    document.querySelectorAll('.view-panel').forEach(el => { el.style.display = 'none'; el.classList.remove('active'); });
    const el = document.getElementById('view-' + id);
    if (!el) return;
    el.style.display = 'block';
    el.classList.add('active');
    // reset content page quand on revient sur cadre
    if (id === 'cadre') {
        currentContentPage = 1;
        document.getElementById('content-page-1').style.display = 'block';
        document.getElementById('content-page-2').style.display = 'none';
    }
    // Sidebar highlight
    document.querySelectorAll('.sidebar-link').forEach(l => { l.classList.remove('active'); l.querySelector('.dot')?.classList.remove('filled'); });
    const navEl = document.getElementById('nav-' + id);
    if (navEl) { navEl.classList.add('active'); navEl.querySelector('.dot')?.classList.add('filled'); }
}

function goTo(id) {
    showView(id);
    if (isTutorialActive) {
        const step = steps[currentStep];
        if (step && step.waitForNavClick && id === step.expectNav) {
            setTimeout(() => nextStep(), 400);
        }
    }
}

const steps = [
    {   // Étape 1 : plan à gauche, on est sur bienvenue
        target: '#nav-plan',
        title: 'LE PLAN DE LA FORMATION',
        content: '📚 À gauche se trouve le plan de la formation. Il liste toutes les séquences organisées par chapitre. Vous pouvez cliquer directement sur un titre pour y accéder à tout moment.',
        setup: () => showView('bienvenue'),
        waitForClick: false,
        position: 'right'
    },
    {   // Étape 2 : cliquer sur "Le cadre de l'audit" dans le menu
        target: '#nav-cadre',
        title: 'NAVIGUER AVEC LE MENU',
        content: '🖱️ Cliquez sur « Le cadre de l\'audit du certificateur » dans le plan pour y accéder directement.',
        setup: () => showView('bienvenue'),
        waitForClick: true,
        waitForNavClick: true,
        expectNav: 'cadre',
        position: 'right'
    },
    {   // Étape 3 : le contenu pédagogique (genially uniquement)
        target: '#genially-content-area',
        title: 'LE CONTENU PÉDAGOGIQUE',
        content: '🖥️ Voici la zone de contenu pédagogique. Chaque séquence affiche un écran interactif (vidéo, schéma, texte…). Naviguez à l\'intérieur grâce aux flèches sur le panneau violet à droite.',
        setup: () => { showView('cadre'); },
        waitForClick: false,
        position: 'under'
    },
    {   // Étape 4 : flèches du panneau violet → cliquer flèche droite
        target: '#purple-panel-area',
        title: 'LES FLÈCHES DE NAVIGATION',
        content: '➡️ Les flèches permettent de naviguer entre les pages d\'une même séquence. La maison 🏠 revient à la première page. Cliquez sur la flèche droite pour voir la page suivante !',
        setup: () => { showView('cadre'); contentGoHome(); },
        waitForClick: false,
        waitForRightArrow: true,
        position: 'left'
    },
    {   // Étape 5 : boutons Marquer/Suivant
        target: '#btn-marquer',
        title: 'VALIDER ET PASSER À LA SUITE',
        content: '✅ Cliquez sur "Marquer comme terminé" pour valider la séquence : le cercle dans le plan devient vert. Le bouton "Suivant" apparaîtra ensuite pour passer à la séquence suivante.',
        setup: () => { showView('cadre'); resetBottomNav(); },
        waitForClick: false,
        allowBottomNav: true,
        position: 'right'
    },
    {   // Étape 6 : récap
        target: '#nav-plan',
        title: 'RÉCAPITULATIF',
        content: '🎉 Vous maîtrisez maintenant les 3 façons de naviguer :\n① Le plan à gauche\n② Le bouton « Suivant »\n③ Les flèches du contenu\nBonne formation !',
        setup: () => showView('cadre'),
        waitForClick: false,
        isLast: true,
        position: 'right'
    }
];

function startTutorial() {
    isTutorialActive = true;
    currentStep = 0;
    document.getElementById('tutorial-container').style.display = 'block';
    renderStep();
}

function endTutorial(showEnd = false) {
    isTutorialActive = false;
    document.getElementById('tutorial-container').style.display = 'none';
    if (showEnd) showView('end');
}

function nextStep() {
    if (currentStep < steps.length - 1) { currentStep++; renderStep(); }
    else endTutorial(true);
}

function prevStep() {
    if (currentStep > 0) { currentStep--; renderStep(); }
}

function handleInteractiveClick() {
    nextStep();
}

function renderStep() {
    const step = steps[currentStep];
    if (step.setup) step.setup();

    const nextBtn = document.getElementById('tut-next');
    // Masquer le bouton Suivant si on attend un clic sur l'interface
    if (step.waitForClick || step.waitForRightArrow) {
        nextBtn.style.display = 'none';
    } else if (step.isLast) {
        nextBtn.innerHTML = '✓ Terminer';
        nextBtn.style.background = '#2563eb';
        nextBtn.style.display = 'inline-block';
    } else {
        nextBtn.innerHTML = 'Suivant →';
        nextBtn.style.background = '#598378';
        nextBtn.style.display = 'inline-block';
    }

    setTimeout(() => {
        const el = document.querySelector(step.target);
        if (!el) return;
        el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

        setTimeout(() => {
            const rect = el.getBoundingClientRect();
            const pad = 8;
            const hole = document.getElementById('tutorial-hole');
            hole.style.top    = (rect.top    - pad) + 'px';
            hole.style.left   = (rect.left   - pad) + 'px';
            hole.style.width  = (rect.width  + pad * 2) + 'px';
            hole.style.height = (rect.height + pad * 2) + 'px';

            // Zone interactive
            const iarea = document.getElementById('tutorial-interactive-area');
            if (step.waitForClick && !step.waitForNavClick) {
                iarea.style.display = 'block';
                iarea.style.top    = (rect.top    - pad) + 'px';
                iarea.style.left   = (rect.left   - pad) + 'px';
                iarea.style.width  = (rect.width  + pad * 2) + 'px';
                iarea.style.height = (rect.height + pad * 2) + 'px';
            } else {
                iarea.style.display = 'none';
                // Pour waitForNavClick, rendre le vrai élément cliquable
                if (step.waitForNavClick) {
                    el.style.pointerEvents = 'auto';
                    document.getElementById('tutorial-container').style.pointerEvents = 'none';
                }
            }
            // Pour waitForRightArrow : activer les zones cliquables sur le panel
            const homeOverlay  = document.getElementById('btn-home-overlay');
            const rightOverlay = document.getElementById('btn-right-overlay');
            if (step.waitForRightArrow) {
                if (homeOverlay)  homeOverlay.style.display  = 'block';
                if (rightOverlay) rightOverlay.style.display = 'block';
                document.getElementById('tutorial-container').style.pointerEvents = 'none';
            } else {
                if (homeOverlay)  homeOverlay.style.display  = 'none';
                if (rightOverlay) rightOverlay.style.display = 'none';
                if (step.allowBottomNav) {
                    // Laisser les boutons bas cliquables
                    document.getElementById('tutorial-container').style.pointerEvents = 'none';
                } else if (!step.waitForNavClick) {
                    document.getElementById('tutorial-container').style.pointerEvents = 'none';
                }
            }

            document.getElementById('tut-badge').textContent = step.title;
            document.getElementById('tut-text').textContent = step.content;
            document.getElementById('tut-counter').textContent = (currentStep + 1) + ' / ' + steps.length;
            document.getElementById('tut-prev').style.opacity = currentStep === 0 ? '0.3' : '1';

            // Position tooltip
            const tt = document.getElementById('tutorial-tooltip');
            const ttW = 310, ttH = 180;
            const vW = window.innerWidth, vH = window.innerHeight;
            let top, left;
            const pos = step.position || 'bottom';

            if (pos === 'right') {
                left = rect.right + 16;
                top = rect.top + rect.height / 2 - ttH / 2;
            } else if (pos === 'left') {
                left = rect.left - ttW - 16;
                top = rect.top + rect.height / 2 - ttH / 2;
            } else if (pos === 'top') {
                left = rect.left + rect.width / 2 - ttW / 2;
                top = rect.top - ttH - 16;
            } else if (pos === 'under') {
                // Centré horizontalement sous l'élément, mais collé à gauche si besoin
                left = rect.left + 16;
                top = rect.bottom + 16;
                // Si ça sort en bas, placer au-dessus
                if (top + ttH > vH) top = rect.top - ttH - 16;
            } else {
                left = rect.left + rect.width / 2 - ttW / 2;
                top = rect.bottom + 16;
            }
            top  = Math.max(10, Math.min(top,  vH - ttH - 10));
            left = Math.max(10, Math.min(left, vW - ttW - 10));
            tt.style.top  = top  + 'px';
            tt.style.left = left + 'px';

        }, 350);
    }, 50);
}

window.addEventListener('resize', () => { if (isTutorialActive) renderStep(); });

// Démarrage
showView('start');
</script>
