                <!-- Image active -->
                <img id="content-page-1" src="data:image/png;base64," alt="Les attendus de France Compétences" class="w-full rounded border border-gray-200 shadow-sm">
                <img id="content-page-2" src="data:image/png;base64," alt="Rappel du processus" class="w-full rounded border border-gray-200 shadow-sm" style="display:none;">    <div id="genially-content-area" style="position:absolute; top:22.3%; left:0%; width:99.8%; height:74.5%; pointer-events:none;"></div>
                    <div id="purple-panel-area" style="position:absolute; top:22.3%; left:92.9%; width:7.1%; height:17%; pointer-events:none; z-index:1;"></div>
                    <!-- Zones cliquables sur les icônes du panel violet -->
                    <div id="btn-home-overlay" onclick="contentGoHome()" 
                         style="position:absolute; top:22.3%; left:92.9%; width:7.1%; height:4.7%; cursor:pointer; z-index:5; display:none;" title="Retour page 1"></div>
                    <div id="btn-right-overlay" onclick="contentGoRight()" 
