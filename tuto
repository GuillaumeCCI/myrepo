            <div class="bg-blue-50 rounded-lg p-16 text-center text-blue-300 text-6xl mb-6"><i class="fas fa-balance-scale"></i></div>
            <div class="flex gap-4"><button class="bg-[#3b5998] text-white px-5 py-2 rounded text-sm">Marquer comme terminé</button><button onclick="goTo('organiser')" class="bg-white text-[#3b5998] border border-[#3b5998] px-5 py-2 rounded text-sm">Suivant</button></div>
        </div>
