        </div>
        <div id="view-fiche" class="view-panel">
            <h2 class="text-3xl font-bold text-gray-900 mb-4">Fiche synthèse – Réunion d'ouverture</h2>
            <div class="bg-red-50 rounded-lg p-16 text-center text-red-300 text-6xl mb-6"><i class="fas fa-file-alt"></i></div>
            <div class="flex gap-4"><button class="bg-[#3b5998] text-white px-5 py-2 rounded text-sm">Marquer comme terminé</button><button onclick="goTo('deroulement')" class="bg-white text-[#3b5998] border border-[#3b5998] px-5 py-2 rounded text-sm">Suivant</button></div>
