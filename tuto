    <div class="flex items-center space-x-6">
        <input type="text" placeholder="Rechercher" class="py-1 px-3 rounded text-gray-800 text-sm w-64 focus:outline-none hidden md:block">
        <a href="#" class="hover:text-blue-300 hidden sm:block">Notifications</a>
        <a href="#" class="hover:text-blue-300 hidden sm:block">Messages</a>
        <a href="#" class="hover:text-blue-300"><i class="fas fa-user-circle mr-1"></i> Mon compte</a>
